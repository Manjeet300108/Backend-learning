<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <h1 class="text-3xl mb-5 tracking-tighter">Create user</h1>
        <form action="/create" method="post">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-md bg-transparent outline-none" name="name" type="text" placeholder="Name">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-md bg-transparent outline-none" name="email" type="text" placeholder="Email">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-md bg-transparent outline-none" name="image" type="text" placeholder="Image Url">
            <input class="px-5 py-2 bg-blue-500 rounded-lg ml-3" type="submit" value="Create User">
        </form>
                <a class="px-3 py-2 text-white inline-block mt-10 rounded-lg bg-blue-500" href="/read">All Users</a>
    </div>

    
</body>

</html>