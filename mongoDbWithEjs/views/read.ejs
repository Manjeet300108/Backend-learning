<!doctype html>
<html>

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 mb-10 inline-block" href="/">Go To Home</a>
        <h1 class="text-3xl mb-3 tracking-tighter">All Users</h1>
        <div class="users flex gap-3 flex-wrap">
            <% if(users.length>0){ %>
                <%users.forEach(function(user){ %>
                    <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                        <div class="w-full h-52 rounded-lg overflow-hidden">
                            <img class="w-full h-full object-cover object-top" src="<%=user.image%>" alt="">
                        </div>
                        <h3 class="text-xl tracking-tighter mt-3">
                            <%=user.name%>
                        </h3>

                        <h5 class="text-zinc-500">
                            <%=user.email%>
                        </h5>
                        <div class="flex gap-10 mt-10">
                            <a class="text-white px-2 py-1 rounded-lg bg-zinc-700 tracking-tighter" href="/edit/<%=user._id%>">Edit User</a>
                            <a class="text-white px-2 py-1 rounded-lg bg-red-500 tracking-tighter" href="/delete/<%=user._id%>">Delete User</a>
                        </div>
                    </div>
                    <% })%>
                        <% } else{ %>
                            <h1>No users</h1>
                            <% } %>

        </div>
    </div>
</body>

</html>