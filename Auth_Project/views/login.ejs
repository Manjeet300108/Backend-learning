<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auth project</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-3">Login User</h3>
        <form method="post" action="/login">
            <input class="px-3 py-2 rounded-lg outline-none bg-transparent border-2 border-zinc-800" type="email" placeholder="Email" name="email">
            <input class="px-3 py-2 rounded-lg outline-none bg-transparent border-2 border-zinc-800" type="password" placeholder="Password" name="password">
            <input class="px-3 py-2 rounded-lg outline-none border-2 border-zinc-800 bg-blue-500" type="submit" value="Login">
        </form>
    </div>
</body>

</html>